# aloud server config. Copy to .env (gitignored) and fill in, or set these as
# host secrets (Fly/Render). Secrets NEVER go in the repo.

# Set to "production" to enforce required-secret checks and the content-check
# downgrade. Anything else (or unset) runs in permissive dev mode.
ALOUD_ENV=

PORT=8787

# Comma-separated origins allowed to call the API from a browser (the static
# ui/dist host). e.g. https://app.aloud.example,https://aloud.example
ALOUD_CORS_ORIGINS=

# Secret for signing our own session JWTs. Generate: openssl rand -hex 32
ALOUD_SESSION_SECRET=

# Google OAuth client id(s) accepted as the audience of incoming ID tokens.
# Comma-separated if you have web + iOS + android client ids.
GOOGLE_CLIENT_IDS=

# Free credits granted to a new VERIFIED account (meditation-pal-2yb).
ALOUD_FREE_SIGNUP_CREDITS=100

# Provider API keys — server-held; the client never sees these. At least one
# required in production.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Stripe (optional in dev). Without these, billing routes report "not
# configured" and the server runs on the free-tier grant alone.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
