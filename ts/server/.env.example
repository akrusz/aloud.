# aloud server config. Copy to .env (gitignored) and fill in, or set these as
# host secrets (Fly/Render). Secrets NEVER go in the repo.

# Set to "production" to enforce required-secret checks and the content-check
# downgrade. Anything else (or unset) runs in permissive dev mode.
ALOUD_ENV=

PORT=8787

# Durable SQLite credit-ledger file. REQUIRED in production — without it the
# server falls back to an in-memory ledger that loses every account balance on
# restart/redeploy. Point it at a persistent volume (on Fly: a mounted volume,
# e.g. /data/aloud.db). Unset in dev = ephemeral in-memory store.
ALOUD_DB_PATH=

# Comma-separated origins allowed to call the API from a browser (the static
# ui/dist host). e.g. https://app.aloud.example,https://aloud.example
ALOUD_CORS_ORIGINS=

# Secret for signing our own session JWTs. Generate: openssl rand -hex 32
ALOUD_SESSION_SECRET=

# Google OAuth client id(s) accepted as the audience of incoming ID tokens.
# Comma-separated if you have web + iOS + android client ids.
GOOGLE_CLIENT_IDS=

# Free credits granted to a new VERIFIED account (meditation-pal-2yb).
# 20 credits ≈ $1.00 of provider cost/signup (credits debit at cost). ~3-4
# mid-tier or ~10 value-tier sessions; bounds abuse blast radius per account.
ALOUD_FREE_SIGNUP_CREDITS=20

# Emergency brake: max free credits granted across ALL signups per rolling hour.
# Default 2000 ≈ 100 signups/hr; only trips on a flood. Tripped signups get 0
# free credits (can still buy) and it's logged.
ALOUD_FREE_GRANT_BUDGET_PER_HOUR=2000

# Provider API keys — server-held; the client never sees these. At least one
# required in production.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Server-side STT (/cloud/v1/stt, Whisper). Backend is config-selected; the
# default is Fireworks (whisper-v3-turbo, ~$0.054/hr — same model/price tier as
# Groq, OpenAI-compatible, open signups). Set ONE key:
#   FIREWORKS_API_KEY  → Fireworks (recommended default)
#   GROQ_API_KEY above → Groq (back-compat; new paid signups may be frozen)
# Or override the backend explicitly (any OpenAI-compatible /audio/transcriptions
# host). STT_PROVIDER is just a log/debit label; STT_BASE_URL and STT_MODEL
# default to Fireworks if omitted:
#   STT_API_KEY=...
#   STT_PROVIDER=openai
#   STT_BASE_URL=https://api.openai.com/v1/audio/transcriptions
#   STT_MODEL=gpt-4o-mini-transcribe
FIREWORKS_API_KEY=

# Gemini direct (Google AI Studio key) — powers the value-tier model
# (gemini-2.5-flash-lite) without OpenRouter's middleman fee. Also doubles as
# the LLM-side Google key; Cloud Text-to-Speech uses GOOGLE_TTS_API_KEY below.
GEMINI_API_KEY=

# Google Cloud Text-to-Speech key (Cloud TTS API enabled) — powers server-side
# TTS (/cloud/v1/tts). Distinct from GEMINI_API_KEY (AI Studio) above; may be the same
# project or a different one. Without it, /cloud/v1/tts reports not-configured and the
# client falls back to browser speechSynthesis.
GOOGLE_TTS_API_KEY=

# Stripe (optional in dev). Without these, billing routes report "not
# configured" and the server runs on the free-tier grant alone.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Bearer token for GET /cloud/v1/admin/metrics (spend monitoring). Unset = endpoint
# disabled (404). Generate: openssl rand -hex 32
ALOUD_ADMIN_TOKEN=

# Optional: serve the built UI (ui/dist) from this same process — the single-box
# "full install" self-host story. Point it at the built UI directory. Leave unset
# for the canonical deploy where the UI is on a static host (e.g. GitHub Pages)
# and this box is API-only. Example: ALOUD_UI_DIR=../ui/dist
ALOUD_UI_DIR=
