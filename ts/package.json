{
    "name": "@aloud/core",
    "version": "0.0.1",
    "private": true,
    "description": "TypeScript port of aloud's orchestration layer (pacing, prompts, session, LLM client). Runs in Node and the browser; intended target is Capacitor for mobile.",
    "type": "module",
    "workspaces": [
        "server"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./src/index.ts",
        "./facilitation": "./src/facilitation/index.ts",
        "./llm": "./src/llm/index.ts",
        "./platform": "./src/platform/index.ts"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p ui/tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "cli": "tsx src/cli.ts",
        "ui:dev": "vite --config ui/vite.config.ts",
        "ui:build": "vite build --config ui/vite.config.ts",
        "ui:preview": "vite preview --config ui/vite.config.ts",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "cap:sync": "npm run ui:build && cap sync",
        "cap:ios": "npm run ui:build && cap sync ios && cap open ios",
        "cap:android": "npm run ui:build && cap sync android && cap open android"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.3.4",
        "@tauri-apps/cli": "^2.11.2",
        "@types/node": "^22.10.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vite": "^6.0.0",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "@capacitor-community/speech-recognition": "^7.0.1",
        "@capacitor/android": "^8.3.4",
        "@capacitor/core": "^8.3.4",
        "@capacitor/ios": "^8.3.4",
        "@tauri-apps/api": "^2.11.0"
    }
}
