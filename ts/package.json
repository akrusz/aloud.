{
    "name": "@glooow/core",
    "version": "0.0.1",
    "private": true,
    "description": "TypeScript port of glooow's orchestration layer (pacing, prompts, session, LLM client). Runs in Node and the browser; intended target is Capacitor for mobile.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./src/index.ts",
        "./facilitation": "./src/facilitation/index.ts",
        "./llm": "./src/llm/index.ts",
        "./platform": "./src/platform/index.ts"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p ui/tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "cli": "tsx src/cli.ts",
        "ui:dev": "vite --config ui/vite.config.ts",
        "ui:build": "vite build --config ui/vite.config.ts",
        "ui:preview": "vite preview --config ui/vite.config.ts"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vite": "^5.4.0",
        "vitest": "^2.1.0"
    }
}
