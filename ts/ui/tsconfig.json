{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        // Vite handles emit; tsc here is for typecheck only. Drop rootDir
        // so we can typecheck the UI sources alongside the imported core.
        "noEmit": true,
        "rootDir": "..",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": []
    },
    "include": ["src/**/*", "../src/**/*"],
    "exclude": ["dist", "node_modules", "../src/cli.ts"]
}
