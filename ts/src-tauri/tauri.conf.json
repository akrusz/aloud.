{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "aloud",
  "version": "0.1.0",
  "identifier": "app.aloud.meditation",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:4649",
    "beforeDevCommand": "npm run ui:dev -- --port 4649 --strictPort",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
