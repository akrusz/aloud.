#!/usr/bin/env bash
# ─────────────────────────────────────────────────
# Glooow.app launcher — finds the project and opens Terminal
# ─────────────────────────────────────────────────

PROJECT_DIR=""

# Strategy 1: .app lives inside the repo (go up 3 dirs from this script)
RELATIVE_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
if [ -f "$RELATIVE_DIR/scripts/start.sh" ]; then
    PROJECT_DIR="$RELATIVE_DIR"
fi

# Strategy 2: breadcrumb file written by setup.sh
if [ -z "$PROJECT_DIR" ]; then
    BREADCRUMB="$(dirname "$0")/../Resources/.glooow-project-path"
    if [ -f "$BREADCRUMB" ]; then
        CANDIDATE="$(cat "$BREADCRUMB")"
        if [ -f "$CANDIDATE/scripts/start.sh" ]; then
            PROJECT_DIR="$CANDIDATE"
        fi
    fi
fi

# Strategy 3: default location
if [ -z "$PROJECT_DIR" ] && [ -f "$HOME/glooow/scripts/start.sh" ]; then
    PROJECT_DIR="$HOME/glooow"
fi

# All strategies failed — show error dialog
if [ -z "$PROJECT_DIR" ]; then
    osascript -e 'display dialog "Could not find the glooow project.\n\nExpected scripts/start.sh in one of:\n• Next to Glooow.app\n• ~/glooow\n\nRe-run setup or move the app into the project folder." with title "Glooow" buttons {"OK"} default button "OK" with icon stop'
    exit 1
fi

# Offer choices
ACTION=$(osascript -e '
tell application "SystemUIServer"
    set choice to button returned of (display dialog "What would you like to do?" with title "Glooow" buttons {"Start", "Uninstall"} default button "Start")
end tell
return choice
' 2>/dev/null || echo "Start")

ESCAPED_DIR=$(printf '%q' "$PROJECT_DIR")

ENV_PREFIX="export GLOOOW_APP=1 &&"

if [ "$ACTION" = "Uninstall" ]; then
    osascript -e "
tell application \"Terminal\"
    activate
    do script \"$ENV_PREFIX cd $ESCAPED_DIR && ./scripts/uninstall.sh\"
end tell
"
else
    osascript -e "
tell application \"Terminal\"
    activate
    do script \"$ENV_PREFIX cd $ESCAPED_DIR && ./scripts/start.sh --open\"
end tell
"
fi
